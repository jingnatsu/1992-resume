<CVLayout title="Nguyễn Hoa Nam - CV">
  <CVHeader
    name="NGUYỄN HOA NAM"
    title="Senior Software Engineer"
    location="Ho Chi Minh City, Vietnam"
    phone="0342347358"
    email="nnguyen92.tdtit@gmail.com"
    linkedin="linkedin.com/in/nguyen-nam-150989130"
    website="tram1992.com/"
    github="https://github.com/jingnatsu"
    photoUrl="public/images/avatar.jpeg"
  />

  <CVSummary
    text="With extensive experience in IT development, I understand how complex systems work. My frontend expertise, backed by backend knowledge, allows me to build optimized, scalable applications. I excel in collaborating with global teams to deliver high-quality software solutions."
  />

