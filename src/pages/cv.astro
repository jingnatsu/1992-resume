const skills = [
  {
    category: 'Frontend',
    items:
      'Next.js, ReactJS, Vite, Astro, Angular, Tailwind CSS, Redux, MobX, JavaScript, TypeScript, HTML/CSS, styled-components',
  },
  {
    category: 'Backend',
    items: 'Java, Spring Boot, NestJS, PostgreSQL, MS SQL, Oracle, Gradle',
