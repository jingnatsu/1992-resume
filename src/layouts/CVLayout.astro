---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&subset=vietnamese&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-100 print:bg-white">
    <div
      class="max-w-[210mm] min-h-[297mm] mx-auto p-[20mm] bg-white print:shadow-none shadow-lg my-5 print:my-0 print:p-0 print:max-w-none"
    >
      <slot />
    </div>

    <style is:global>
      @media print {
        body {
          background: white;
          padding: 0;
          margin: 0;
        }

        /* @page margin ensures every page (including continuations) has proper spacing */
        @page {
          size: A4;
          margin: 20mm;
        }

        /* Clear all margin boxes, only show page number at bottom center */
        @page {
          @top-left {
            content: '';
          }
          @top-center {
            content: '';
          }
          @top-right {
            content: '';
          }
          @bottom-left {
            content: '';
          }
          @bottom-center {
            content: counter(page);
            font-size: 10pt;
            color: #666;
          }
          @bottom-right {
            content: '';
          }
        }

        /* Keep section heading attached to first entry below it */
        h2 {
          break-after: avoid;
          page-break-after: avoid;
        }
      }
    </style>
  </body>
</html>
