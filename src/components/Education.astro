---
interface Props {
  period: string;
  degree: string;
  university: string;
  location: string;
}

const { period, degree, university, location } = Astro.props;
---

<section class="mb-7">
  <h2
    class="text-base font-bold text-blue-900 mb-3 tracking-wide border-b-2 border-blue-900 pb-1"
  >
    Education
  </h2>
  <div class="text-xs">
    <div class="font-semibold text-blue-800 mb-1">{period}</div>
    <div class="text-xs font-bold text-slate-900">{degree}</div>
    <div class="text-slate-600">{university}</div>
    <div class="text-slate-500">{location}</div>
  </div>
</section>
