---
interface Skill {
  category: string;
  items: string;
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<section class="mb-7">
  <h2
    class="text-base font-bold text-blue-900 mb-3 tracking-wide border-b-2 border-blue-900 pb-1"
  >
    Qualifications
  </h2>
  <div class="text-xs">
    <div class="font-semibold text-slate-700 mb-2 uppercase tracking-wide">
      Technical Skills
    </div>
    <div class="grid gap-1.5 text-xs">
      {
        skills.map(skill => (
          <div class="flex items-start gap-2">
            <svg
              class="mt-[2px] shrink-0 text-blue-500"
              width="10"
              height="10"
              viewBox="0 0 10 10"
              fill="currentColor"
            >
              <rect x="1" y="1" width="8" height="8" rx="1.5" />
            </svg>
            <div class="flex flex-1 gap-1">
              <span class="font-semibold text-slate-800 min-w-[80px]">
                {skill.category}:
              </span>
              <span class="text-slate-600">{skill.items}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
