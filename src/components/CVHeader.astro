---
interface Props {
  name: string;
  title: string;
  location: string;
  phone: string;
  email: string;
  linkedin: string;
  website: string;
  photoUrl?: string;
}

const { name, title, location, phone, email, linkedin, website, photoUrl } =
  Astro.props;
---

<div class="flex gap-6 pb-6">
  <div class="flex-shrink-0">
    <img
      src={photoUrl ||
        'https://via.placeholder.com/130x160/cccccc/666666?text=Photo'}
      alt="Profile Photo"
      class="w-[130px] h-[160px] object-cover"
    />
  </div>
  <div class="flex-1">
    <h1 class="text-[32px] font-bold text-black mb-1 tracking-wide">{name}</h1>
    <div class="text-base font-semibold text-black mb-3">{title}</div>
    <div
      class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-700 items-center"
    >
      <span>{location}</span>
      <span class="text-gray-500">|</span>
      <span>{phone}</span>
      <span class="text-gray-500">|</span>
      <a href={`mailto:${email}`} class="text-blue-600 hover:underline"
        >{email}</a
      >
      <br />
      <span class="mr-1">🔗</span>
      <a href={`https://${linkedin}`} class="text-blue-600 hover:underline"
        >{linkedin}</a
      >
      <span class="text-gray-500">|</span>
      <span class="mr-1">🌐</span>
      <a href={`https://${website}`} class="text-blue-600 hover:underline"
        >{website}</a
      >
    </div>
  </div>
</div>
