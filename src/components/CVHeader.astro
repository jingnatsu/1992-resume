---
interface Props {
  name: string;
  title: string;
  location: string;
  phone: string;
  email: string;
  linkedin: string;
  website: string;
  photoUrl?: string;
}

const { name, title, location, phone, email, linkedin, website, photoUrl } =
  Astro.props;
---

<header class="flex gap-6 pb-5">
  {
    photoUrl && (
      <div class="flex-shrink-0">
        <img
          src={photoUrl}
          alt={name}
          class="w-[100px] h-[130px] object-cover object-top border-2 border-slate-200"
        />
      </div>
    )
  }

  <div class="flex-1 flex flex-col justify-between">
    <!-- Name & Title -->
    <div>
      <h1
        class="text-[28px] font-bold text-slate-900 tracking-wide uppercase leading-tight"
      >
        {name}
      </h1>
      <p
        class="text-[13px] font-semibold text-slate-500 uppercase tracking-[0.15em] mt-0.5"
      >
        {title}
      </p>
    </div>

    <!-- Contact Info -->
    <div class="flex flex-col gap-1 text-[11.5px] text-slate-600 mt-3">
      <!-- Line 1: Phone | Email | Location -->
      <div class="flex items-center gap-x-3">
        <span class="flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-slate-400"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          {phone}
        </span>
        <span class="text-slate-300">|</span>
        <a
          href={`mailto:${email}`}
          class="flex items-center gap-1 hover:text-slate-900 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-slate-400"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          {email}
        </a>
        <span class="text-slate-300">|</span>
        <span class="flex items-center gap-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-slate-400"
          >
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {location}
        </span>
      </div>

      <!-- Line 2: LinkedIn -->
      <a
        href={`https://${linkedin}`}
        target="_blank"
        class="flex items-center gap-1 hover:text-slate-900 transition-colors w-fit"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="11"
          height="11"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-slate-400"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
        {linkedin}
      </a>

      <!-- Line 3: Website -->
      <a
        href={`https://${website}`}
        target="_blank"
        class="flex items-center gap-1 hover:text-slate-900 transition-colors w-fit"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="11"
          height="11"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-slate-400"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="2" x2="22" y1="12" y2="12"></line>
          <path
            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path>
        </svg>
        {website}
      </a>
    </div>
  </div>
</header>
